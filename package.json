{
  "name": "storage-reward-distributor",
  "version": "0.1.0",
  "description": "Hourly cron that distributes storage rewards on Base + SKALE RewardEngine contracts. Pool operator-driven; hosted on GitHub Actions; configurable via a static UI on GitHub Pages.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "tick": "tsx src/index.ts tick",
    "ingest": "tsx src/index.ts ingest",
    "status": "tsx src/index.ts status",
    "dry-run": "DRY_RUN=true tsx src/index.ts tick",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "web:dev": "npm run dev --workspace @app/web",
    "web:build": "npm run build --workspace @app/web"
  },
  "dependencies": {
    "ethers": "^6.13.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.6"
  }
}
